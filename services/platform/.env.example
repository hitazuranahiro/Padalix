DATABASE_URL=postgresql://padalix:padalix-local-only@127.0.0.1:5432/padalix?sslmode=disable
PLATFORM_INTERNAL_TOKEN=replace-with-a-local-secret

# Audit-only by default. Enable only after migration 017, reviewer queues, and
# alert ownership have been validated. Review/block findings then fail closed.
COMPLIANCE_ENFORCEMENT_ENABLED=false

# Deploy migration 024 and the matching web/API release before enabling.
# When enabled, non-exempt platform routes return HTTP 428 until the member
# accepts the current published terms version.
TERMS_ACCEPTANCE_ENFORCED=false

STELLAR_TESTNET_PAYMENTS_ENABLED=true
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_PAYMENT_ASSET_CODE=XLM

WORKER_ID=padalix-worker-local
WORKER_POLL_INTERVAL=2s
WORKER_LOCK_TIMEOUT=2m

# Keep false until the SES sending domain has production access.
EMAIL_DELIVERY_ENABLED=false
EMAIL_PROVIDER=ses
EMAIL_FROM=Padalix <notifications@padalix.com>
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=replace-with-ses-send-only-access-key
AWS_SECRET_ACCESS_KEY=replace-with-ses-send-only-secret-key
EMAIL_SES_CONFIGURATION_SET=

# Legacy/custom HTTPS provider configuration (only for EMAIL_PROVIDER=webhook).
EMAIL_PROVIDER_URL=https://email-provider.example/v1/send
EMAIL_PROVIDER_TOKEN=replace-from-secret-manager

# Ganap is a PHP funding checkout, not a recipient payout or Stellar anchor.
# Keep disabled until migration 019 is applied, the pasted API key is rotated,
# redirects are verified, and the connector row is explicitly moved to pilot.
GANAP_CHECKOUT_ENABLED=false
GANAP_CHECKOUT_URL=https://api.ganap.net/api/merchant-project/replace-project-id/webhook-checkout
GANAP_SECRET_KEY=replace-from-secret-manager
GANAP_REDIRECT_ALLOWED_ORIGINS=https://app.padalix.com
GANAP_WEBHOOK_PATH_SECRET=replace-with-32-to-128-url-safe-random-characters
# Configure these only if Ganap can send a custom secret header.
GANAP_WEBHOOK_HEADER_NAME=
GANAP_WEBHOOK_HEADER_SECRET=
GANAP_TIMEOUT_SECONDS=10
