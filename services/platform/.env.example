DATABASE_URL=postgresql://padalix:padalix-local-only@127.0.0.1:5432/padalix?sslmode=disable
PLATFORM_INTERNAL_TOKEN=replace-with-a-local-secret

STELLAR_TESTNET_PAYMENTS_ENABLED=true
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_PAYMENT_ASSET_CODE=XLM

WORKER_ID=padalix-worker-local
WORKER_POLL_INTERVAL=2s
WORKER_LOCK_TIMEOUT=2m

# Keep false until the SES sending domain has production access.
EMAIL_DELIVERY_ENABLED=false
EMAIL_PROVIDER=ses
EMAIL_FROM=Padalix <notifications@padalix.com>
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=replace-with-ses-send-only-access-key
AWS_SECRET_ACCESS_KEY=replace-with-ses-send-only-secret-key
EMAIL_SES_CONFIGURATION_SET=

# Legacy/custom HTTPS provider configuration (only for EMAIL_PROVIDER=webhook).
EMAIL_PROVIDER_URL=https://email-provider.example/v1/send
EMAIL_PROVIDER_TOKEN=replace-from-secret-manager
